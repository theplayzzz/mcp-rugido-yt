# Copie este arquivo para .env e preencha. NÃO comite o .env.

# === Postgres ===
# Em dev local com docker-compose: postgresql+asyncpg://rugido:rugido_dev@db:5432/mcp_rugido_yt
# Em Dokploy, aponte pro service Postgres interno (nome do service como host)
DATABASE_URL=postgresql+asyncpg://rugido:rugido_dev@db:5432/mcp_rugido_yt

# === Servidor ===
MCP_HOST=0.0.0.0
MCP_PORT=8000
# URL pública HTTPS por onde o servidor é acessado externamente.
# Usada pra montar o redirect_uri do Google. DEVE bater exatamente com o
# Authorized redirect URI cadastrado no Google Cloud Console.
MCP_PUBLIC_BASE_URL=https://mcp-rugido-yt.gruporugido.com

# === Google OAuth (Web application) ===
# Crie no Google Cloud Console > APIs & Services > Credentials > OAuth client ID > Web application.
# Authorized redirect URI deve ser exatamente: ${MCP_PUBLIC_BASE_URL}/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Cripto ===
# Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Se essa chave for perdida, todos os refresh_tokens criptografados ficam ilegíveis
# e os usuários precisam refazer o consent.
FERNET_KEY=

# === Opcional ===
# API key Google pra operações que não exigem OAuth (raras nessa app)
YOUTUBE_API_KEY=
# Limite diário de quota da YouTube Data API (default 10000)
DAILY_QUOTA_LIMIT=10000

# Token de verificação do Google Search Console (sem o "google-site-verification=").
# Setar SOMENTE quando for verificar propriedade do domínio pra Verificação OAuth.
# Ex: GOOGLE_SITE_VERIFICATION=abc123XYZ_de4f5g6h7i8j9k0l
GOOGLE_SITE_VERIFICATION=
